@model CarInsurance.Models.Insuree
@{
    Layout = null;
    ViewBag.Title = "Create Insuree Profile";
}

<!DOCTYPE html>
<html>
<head>
    <title>Create Profile</title>
    <link rel="stylesheet" href="https://cloudflare.com" />
</head>
<body class="container" style="padding-top: 30px;">

    <h2>Create Insuree Profile</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
<div class="form-horizontal">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="form-group mb-2">First Name: @Html.EditorFor(m => m.FirstName, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">Last Name: @Html.EditorFor(m => m.LastName, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">Email: @Html.EditorFor(m => m.EmailAddress, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">DOB: @Html.EditorFor(m => m.DateOfBirth, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">Car Year: @Html.EditorFor(m => m.CarYear, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">Car Make: @Html.EditorFor(m => m.CarMake, new { htmlAttributes = new { @class = "form-control" } })</div>
    <!-- FIXED LINE BELOW -->

    <div class="form-group mb-2">Car Model: @Html.EditorFor(m => m.CarModel, new { htmlAttributes = new { @class = "form-control" } })</div>



    <div class="form-group mb-2">DUI: @Html.CheckBoxFor(m => m.DUI)</div>
    <div class="form-group mb-2">Tickets: @Html.EditorFor(m => m.SpeedingTickets, new { htmlAttributes = new { @class = "form-control" } })</div>
    <div class="form-group mb-2">Full Coverage: @Html.CheckBoxFor(m => m.CoverageType)</div>
    <div class="form-group mb-3">Quote Value: @Html.EditorFor(m => m.Quote, new { htmlAttributes = new { @class = "form-control" } })</div>
    <input type="submit" value="Create" class="btn btn-primary" />
</div>
    }

</body>
</html>
