@{
    Layout = null;
    ViewBag.Title = "Insurees List";
}
@model IEnumerable<CarInsurance.Models.Insuree>

<!DOCTYPE html>
<html>
<head>
    <title>Insurees List</title>
    <link rel="stylesheet" href="https://cloudflare.com" />
</head>
<body class="container" style="padding-top: 30px;">

    <h2>Insurees List</h2>
    <p>@Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-primary" })</p>
    <table class="table table-striped">
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Quote</th>
            <th>Actions</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.EmailAddress</td>
                <td>$@item.Quote</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </table>

</body>
</html>



